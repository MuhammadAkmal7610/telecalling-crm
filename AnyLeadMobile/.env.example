# Environment Configuration for AnyLead Mobile CRM
# Copy this file to .env and fill in your actual values

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ===========================================
# WHATSAPP BUSINESS API CONFIGURATION
# ===========================================
# WhatsApp Business API Provider (BSP) Configuration
EXPO_PUBLIC_WHATSAPP_PROVIDER=twilio  # Options: twilio, messagebird, gupshup, etc.

# Twilio Configuration (if using Twilio as BSP)
EXPO_PUBLIC_TWILIO_ACCOUNT_SID=your_twilio_account_sid
EXPO_PUBLIC_TWILIO_AUTH_TOKEN=your_twilio_auth_token
EXPO_PUBLIC_TWILIO_WHATSAPP_NUMBER=your_twilio_whatsapp_number

# MessageBird Configuration (if using MessageBird)
EXPO_PUBLIC_MESSAGEBIRD_ACCESS_KEY=your_messagebird_access_key
EXPO_PUBLIC_MESSAGEBIRD_WHATSAPP_NUMBER=your_messagebird_whatsapp_number

# Gupshup Configuration (if using Gupshup)
EXPO_PUBLIC_GUPSHUP_API_KEY=your_gupshup_api_key
EXPO_PUBLIC_GUPSHUP_APP_NAME=your_gupshup_app_name

# Direct WhatsApp Business API (if you have direct access)
EXPO_PUBLIC_WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
EXPO_PUBLIC_WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id
EXPO_PUBLIC_WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
EXPO_PUBLIC_WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_whatsapp_webhook_verify_token

# ===========================================
# WHATSAPP WEBHOOK CONFIGURATION
# ===========================================
EXPO_PUBLIC_WHATSAPP_WEBHOOK_URL=https://your-server.com/webhooks/whatsapp
EXPO_PUBLIC_WHATSAPP_WEBHOOK_SECRET=your_webhook_secret_key

# ===========================================
# DIALER INTEGRATION CONFIGURATION
# ===========================================
# Twilio for Voice Calls (if using Twilio)
EXPO_PUBLIC_TWILIO_VOICE_APPLICATION_SID=your_twilio_voice_app_sid

# Vonage (Nexmo) for Voice Calls (if using Vonage)
EXPO_PUBLIC_VONAGE_API_KEY=your_vonage_api_key
EXPO_PUBLIC_VONAGE_API_SECRET=your_vonage_api_secret

# Plivo for Voice Calls (if using Plivo)
EXPO_PUBLIC_PLIVO_AUTH_ID=your_plivo_auth_id
EXPO_PUBLIC_PLIVO_AUTH_TOKEN=your_plivo_auth_token

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
EXPO_PUBLIC_APP_URL=https://your-crm-app.com
EXPO_PUBLIC_API_BASE_URL=https://your-api-server.com/api
EXPO_PUBLIC_APP_NAME=AnyLead CRM
EXPO_PUBLIC_APP_VERSION=1.0.0

# ===========================================
# ANALYTICS & MONITORING
# ===========================================
EXPO_PUBLIC_SENTRY_DSN=your_sentry_dsn_for_error_tracking
EXPO_PUBLIC_ANALYTICS_ENABLED=true

# ===========================================
# DEVELOPMENT/PRODUCTION FLAGS
# ===========================================
EXPO_PUBLIC_ENVIRONMENT=development  # Options: development, staging, production
EXPO_PUBLIC_DEBUG_MODE=true
EXPO_PUBLIC_LOG_LEVEL=info  # Options: debug, info, warn, error

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
EXPO_PUBLIC_ENCRYPTION_KEY=your_32_character_encryption_key
EXPO_PUBLIC_JWT_SECRET=your_jwt_secret_key

# ===========================================
# PUSH NOTIFICATION CONFIGURATION
# ===========================================
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
EXPO_PUBLIC_FIREBASE_SERVER_KEY=your_firebase_server_key

# ===========================================
# STORAGE CONFIGURATION
# ===========================================
EXPO_PUBLIC_AWS_S3_BUCKET=your_s3_bucket_name
EXPO_PUBLIC_AWS_ACCESS_KEY_ID=your_aws_access_key
EXPO_PUBLIC_AWS_SECRET_ACCESS_KEY=your_aws_secret_key
EXPO_PUBLIC_AWS_REGION=us-east-1

# ===========================================
# EMAIL CONFIGURATION (for notifications)
# ===========================================
EXPO_PUBLIC_SENDGRID_API_KEY=your_sendgrid_api_key
EXPO_PUBLIC_EMAIL_FROM=noreply@your-crm-app.com

# ===========================================
# SOCIAL MEDIA INTEGRATION
# ===========================================
# Facebook Lead Ads
EXPO_PUBLIC_FACEBOOK_APP_ID=your_facebook_app_id
EXPO_PUBLIC_FACEBOOK_APP_SECRET=your_facebook_app_secret
EXPO_PUBLIC_FACEBOOK_ACCESS_TOKEN=your_facebook_access_token

# Instagram Business
EXPO_PUBLIC_INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token

# LinkedIn
EXPO_PUBLIC_LINKEDIN_CLIENT_ID=your_linkedin_client_id
EXPO_PUBLIC_LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Twitter/X
EXPO_PUBLIC_TWITTER_API_KEY=your_twitter_api_key
EXPO_PUBLIC_TWITTER_API_SECRET=your_twitter_api_secret
EXPO_PUBLIC_TWITTER_ACCESS_TOKEN=your_twitter_access_token
EXPO_PUBLIC_TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret

# ===========================================
# PAYMENT PROCESSING (if needed)
# ===========================================
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
EXPO_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id
